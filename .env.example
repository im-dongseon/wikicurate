# defrag Configuration Example
# Copy this file to .env and update the variables with your own settings.

# List of absolute paths to your Obsidian vault directories.
# Example:
# DEPLOY_PATHS=(
#   "/Users/yourname/Documents/my-vault-1"
#   "/Users/yourname/Documents/my-vault-2"
# )
DEPLOY_PATHS=(
  "/path/to/your/defrag-vault"
)
